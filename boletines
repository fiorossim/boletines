          <span className={`text-[9px] uppercase tracking-wider px-1.5 py-0.5 rounded ${isMulti ? 'bg-[#c2410c]/10 text-[#c2410c]' : 'bg-[#4d7c0f]/10 text-[#4d7c0f]'}`}>
            {isMulti ? 'varios' : 'uno'}
          </span>
        </div>
      )}
