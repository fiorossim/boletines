// ---------- generator ----------
const joinPhrases = (phrases) => {
  if (phrases.length === 0) return '';
  if (phrases.length === 1) return phrases[0];
  if (phrases.length === 2) return `${phrases[0]} y ${phrases[1]}`;
  return `${phrases.slice(0, -1).join(', ')} y ${phrases[phrases.length - 1]}`;
};

const lowerFirst = (s) => s ? s.charAt(0).toLowerCase() + s.slice(1) : s;

const generateBoletin = (student, structure, activePeriodId) => {
  if (!student) return { plain: '', sections: [] };

  const sel = student.periodSelections?.[activePeriodId] || {};
  const sections = [];

  structure.forEach((comp) => {
    const lines = [];
    comp.categories.forEach((cat) => {
      const fragments = [];

      cat.groups.forEach((group) => {
        const groupSel = sel[group.id];
        let texts = [];
        if (group.type === 'single') {
          if (groupSel) {
            const desc = group.descriptors.find(x => x.id === groupSel);
            if (desc) texts = [desc.text];
          }
        } else {
          if (Array.isArray(groupSel)) {
            texts = groupSel
              .map(id => group.descriptors.find(x => x.id === id))
              .filter(Boolean)
              .map(x => x.text);
          }
        }
        if (texts.length === 0) return;

        if (group.name && group.name.trim()) {
          const joined = joinPhrases(texts).replace(/\.\s*$/, '');
          fragments.push(`${group.name}: ${joined}.`);
        } else {
          texts.forEach(t => fragments.push(t));
        }
      });

      if (fragments.length === 0) return;

      let line;
      const connector = (cat.connector || '').trim();
      if (connector) {
        const first = lowerFirst(fragments[0]);
        const rest = fragments.slice(1).join(' ');
        line = `${connector} ${first}${rest ? ' ' + rest : ''}`;
      } else {
        line = fragments.join(' ');
      }
      lines.push(line);
    });

    if (lines.length > 0) {
      sections.push({ title: comp.name, paragraph: lines.join(' ') });
    }
  });

  const plain = sections.map(s => `${s.title}\n${s.paragraph}`).join('\n\n');
  return { plain, sections };
};

// migration
const migrate = (data) => {
  let { structure, periods, students, selectedStudentId, activePeriodId } = data;

  // ensure periods exist
  if (!Array.isArray(periods) || periods.length === 0) {
    periods = makeDefaultPeriods();
  }

  // ensure activePeriodId is valid
  if (!periods.find(p => p.id === activePeriodId)) {
    activePeriodId = periods[0].id;
  }

  // structure: ensure connector field on categories
  if (Array.isArray(structure)) {
    structure = structure.map(comp => ({
      ...comp,
      categories: (comp.categories || []).map(cat => ({
        connector: '',
        ...cat,
      }))
    }));
  }

  // students: convert old `selections` to periodSelections under first period
  if (Array.isArray(students)) {
    students = students.map(s => {
      if (s.periodSelections) return s;
      if (s.selections) {
        const firstPeriodId = periods[0].id;
        return {
          id: s.id,
          name: s.name,
          periodSelections: { [firstPeriodId]: s.selections }
        };
      }
      return { ...s, periodSelections: {} };
    });
  }

  return { structure, periods, students, selectedStudentId, activePeriodId };
};

