          return (
            <button
              key={d.id}
              onClick={() => isMulti ? onToggleMulti(group.id, d.id) : onSetSingle(group.id, d.id)}
              className={`w-full text-left flex items-start gap-2.5 px-3 py-2 rounded-lg border transition text-sm ${
                checked
                  ? 'border-[#1a1d24] bg-[#1a1d24] text-[#faf7f2]'
                  : 'border-[#1a1d24]/10 hover:border-[#1a1d24]/30 bg-white text-[#1a1d24]/80'
              }`}
            >
              <span
                className={`flex-shrink-0 w-4 h-4 mt-0.5 flex items-center justify-center transition ${
                  isMulti ? 'rounded' : 'rounded-full'
                } ${
                  checked
                    ? 'bg-[#faf7f2] text-[#1a1d24]'
                    : 'border border-[#1a1d24]/30'
                }`}
              >
                {checked && (isMulti ? <Check size={10} strokeWidth={3} /> : <span className="w-1.5 h-1.5 bg-[#1a1d24] rounded-full" />)}
              </span>
              <div className="flex-1 leading-snug">
                {d.label && (
                  <span className={`inline-block text-[9px] uppercase tracking-wider font-bold px-1.5 py-0.5 rounded mr-1.5 ${
                    checked ? 'bg-[#faf7f2]/20 text-[#faf7f2]' : 'bg-[#c2410c]/10 text-[#c2410c]'
                  }`}>
                    {d.label}
                  </span>
                )}
                <span>{d.text}</span>
              </div>
            </button>
          );
        })}
      </div>
    </div>
  );
}

