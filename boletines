// ---------- structure editor ----------
function StructureEditor({ structure, setStructure, periods, onAddPeriod, onRenamePeriod, onRemovePeriod, onResetDefault }) {
  const [openComp, setOpenComp] = useState({});
  const [openCat, setOpenCat] = useState({});

  const toggleComp = (id) => setOpenComp({ ...openComp, [id]: !openComp[id] });
  const toggleCat = (id) => setOpenCat({ ...openCat, [id]: !openCat[id] });

  const updateStructure = (mutator) => {
    const copy = JSON.parse(JSON.stringify(structure));
    mutator(copy);
    setStructure(copy);
  };

  const addComp = () => {
    const name = prompt('Nombre de la competencia:');
    if (!name?.trim()) return;
    setStructure([...structure, { id: uid(), name: name.trim(), categories: [] }]);
  };

  const renameComp = (compId) => {
    const c = structure.find(x => x.id === compId);
    const name = prompt('Nuevo nombre:', c?.name);
    if (!name?.trim()) return;
    updateStructure(s => {
      const found = s.find(x => x.id === compId);
      if (found) found.name = name.trim();
    });
  };

  const deleteComp = (compId) => {
    if (!confirm('¿Eliminar competencia y todo su contenido?')) return;
    setStructure(structure.filter(x => x.id !== compId));
  };

  const addCat = (compId) => {
    const name = prompt('Nombre de la categoría:');
    if (!name?.trim()) return;
    updateStructure(s => {
      const c = s.find(x => x.id === compId);
      if (c) c.categories.push({
        id: uid(),
        name: name.trim(),
        connector: '',
        groups: [{ id: uid(), name: '', type: 'single', descriptors: [] }]
      });
    });
  };

  const updateCat = (compId, catId, patch) => {
    updateStructure(s => {
      const found = s.find(c => c.id === compId).categories.find(x => x.id === catId);
      if (found) Object.assign(found, patch);
    });
  };

  const renameCat = (compId, catId) => {
    const cat = structure.find(c => c.id === compId)?.categories.find(x => x.id === catId);
    const name = prompt('Nuevo nombre:', cat?.name);
    if (!name?.trim()) return;
    updateCat(compId, catId, { name: name.trim() });
  };

  const deleteCat = (compId, catId) => {
    if (!confirm('¿Eliminar categoría?')) return;
    updateStructure(s => {
      const c = s.find(x => x.id === compId);
      c.categories = c.categories.filter(x => x.id !== catId);
    });
  };

  const addGroup = (compId, catId) => {
    const name = prompt('Nombre del grupo (opcional, dejá vacío si es el grupo principal):') || '';
    const typeAns = prompt('Tipo: escribí "uno" para selección única, "varios" para selección múltiple', 'uno');
    const type = typeAns?.toLowerCase().startsWith('v') ? 'multi' : 'single';
    updateStructure(s => {
      const cat = s.find(c => c.id === compId).categories.find(x => x.id === catId);
      cat.groups.push({ id: uid(), name: name.trim(), type, descriptors: [] });
    });
  };

  const updateGroup = (compId, catId, groupId, patch) => {
    updateStructure(s => {
      const g = s.find(c => c.id === compId).categories.find(x => x.id === catId).groups.find(x => x.id === groupId);
      Object.assign(g, patch);
    });
  };

  const deleteGroup = (compId, catId, groupId) => {
    if (!confirm('¿Eliminar grupo y sus descriptores?')) return;
    updateStructure(s => {
      const cat = s.find(c => c.id === compId).categories.find(x => x.id === catId);
      cat.groups = cat.groups.filter(x => x.id !== groupId);
    });
  };

  const addDescriptor = (compId, catId, groupId) => {
    updateStructure(s => {
      const g = s.find(c => c.id === compId).categories.find(x => x.id === catId).groups.find(x => x.id === groupId);
      g.descriptors.push({ id: uid(), text: '', label: '' });
    });
  };

  const updateDescriptor = (compId, catId, groupId, descId, patch) => {
    updateStructure(s => {
      const g = s.find(c => c.id === compId).categories.find(x => x.id === catId).groups.find(x => x.id === groupId);
      const found = g.descriptors.find(x => x.id === descId);
      if (found) Object.assign(found, patch);
    });
  };

  const deleteDescriptor = (compId, catId, groupId, descId) => {
    updateStructure(s => {
      const g = s.find(c => c.id === compId).categories.find(x => x.id === catId).groups.find(x => x.id === groupId);
      g.descriptors = g.descriptors.filter(x => x.id !== descId);
    });
  };

  return (
    <div className="max-w-5xl mx-auto px-6 py-6">
      <div className="flex items-center justify-between mb-6 flex-wrap gap-3">
        <div>
          <h2 className="font-display text-3xl font-semibold tracking-tight">Estructura</h2>
          <p className="text-sm text-[#1a1d24]/60 mt-1">Períodos, competencias, categorías, grupos y descriptores.</p>
        </div>
        <div className="flex items-center gap-2">
          <button onClick={onResetDefault} className="text-xs text-[#1a1d24]/60 hover:text-[#1a1d24] flex items-center gap-1">
            <RotateCcw size={12} /> ejemplo
          </button>
          <button onClick={addComp} className="flex items-center gap-1.5 px-3 py-2 bg-[#1a1d24] text-[#faf7f2] rounded-lg text-sm font-medium">
            <Plus size={14} /> Competencia
          </button>
        </div>
      </div>

      {/* Periods section */}
      <div className="bg-white border border-[#1a1d24]/10 rounded-2xl overflow-hidden mb-5">
        <div className="px-5 py-3 bg-[#faf7f2] border-b border-[#1a1d24]/10 flex items-center justify-between">
          <div className="flex items-center gap-2">
            <Calendar size={14} className="text-[#c2410c]" />
            <h3 className="font-display text-base font-semibold">Períodos del año</h3>
          </div>
          <button onClick={onAddPeriod} className="text-xs flex items-center gap-1 text-[#1a1d24]/70 hover:text-[#1a1d24]">
            <Plus size={12} /> añadir período
          </button>
        </div>
        <div className="p-4 space-y-2">
          {periods.map((p, i) => (
            <div key={p.id} className="flex items-center gap-3 px-3 py-2 border border-[#1a1d24]/10 rounded-lg bg-[#faf7f2]">
              <span className="text-xs uppercase tracking-wider font-bold text-[#c2410c] w-8">{i + 1}°</span>
              <span className="flex-1 text-sm font-medium">{p.name}</span>
              <IconBtn onClick={() => onRenamePeriod(p.id)} title="Renombrar"><Edit3 size={12} /></IconBtn>
              <IconBtn onClick={() => onRemovePeriod(p.id)} title="Eliminar" danger><Trash2 size={12} /></IconBtn>
            </div>
          ))}
          <p className="text-[11px] text-[#1a1d24]/40 italic mt-2">
            Cada estudiante tiene marcas independientes por período. Los descriptores son globales: si agregás uno nuevo en cualquier momento, queda disponible en todos los períodos.
          </p>
        </div>
      </div>

      {/* Structure */}
      <div className="space-y-3">
        {structure.map((comp) => {
          const open = openComp[comp.id];
          const totalDesc = comp.categories.reduce(
            (acc, c) => acc + c.groups.reduce((a, g) => a + g.descriptors.length, 0), 0
          );
          return (
            <div key={comp.id} className="bg-white border border-[#1a1d24]/10 rounded-2xl overflow-hidden">
              <div className="flex items-center justify-between px-5 py-3 bg-[#faf7f2] border-b border-[#1a1d24]/10">
                <button onClick={() => toggleComp(comp.id)} className="flex items-center gap-2 flex-1 text-left">
                  {open ? <ChevronDown size={16} /> : <ChevronRight size={16} />}
                  <h3 className="font-display text-lg font-semibold">{comp.name}</h3>
                  <span className="text-xs text-[#1a1d24]/40">
                    {comp.categories.length} categorías · {totalDesc} descriptores
                  </span>
                </button>
                <div className="flex items-center gap-1">
                  <IconBtn onClick={() => renameComp(comp.id)} title="Renombrar"><Edit3 size={14} /></IconBtn>
                  <IconBtn onClick={() => deleteComp(comp.id)} title="Eliminar" danger><Trash2 size={14} /></IconBtn>
                </div>
              </div>
              {open && (
                <div className="p-5 space-y-3">
                  {comp.categories.map((cat) => {
                    const catOpen = openCat[cat.id];
                    return (
                      <div key={cat.id} className="border border-[#1a1d24]/10 rounded-xl overflow-hidden">
                        <div className="flex items-center justify-between px-4 py-2.5 bg-[#1a1d24]/[0.02]">
                          <button onClick={() => toggleCat(cat.id)} className="flex items-center gap-2 flex-1 text-left">
                            {catOpen ? <ChevronDown size={14} /> : <ChevronRight size={14} />}
                            <h4 className="text-sm font-semibold uppercase tracking-wider text-[#1a1d24]/70">{cat.name}</h4>
                            <span className="text-[11px] text-[#1a1d24]/40">{cat.groups.length} grupos</span>
                          </button>
                          <div className="flex items-center gap-1">
                            <IconBtn onClick={() => renameCat(comp.id, cat.id)} title="Renombrar"><Edit3 size={12} /></IconBtn>
                            <IconBtn onClick={() => deleteCat(comp.id, cat.id)} title="Eliminar" danger><Trash2 size={12} /></IconBtn>
                          </div>
                        </div>
                        {catOpen && (
                          <div className="p-3 space-y-3">
                            <div>
                              <label className="text-[10px] uppercase tracking-wider font-semibold text-[#1a1d24]/50 block mb-1">
                                Conector narrativo (opcional)
                              </label>
                              <input
                                value={cat.connector || ''}
                                onChange={(e) => updateCat(comp.id, cat.id, { connector: e.target.value })}
                                placeholder='ej. "En relación con sus producciones escritas," o dejar vacío'
                                className="w-full text-sm bg-[#faf7f2] border border-[#1a1d24]/10 rounded px-3 py-2 outline-none focus:border-[#1a1d24]/30"
                              />
                              <p className="text-[10px] text-[#1a1d24]/40 mt-1 italic">
                                Si lo completás, encabeza la línea y la primera letra del descriptor pasa a minúscula.
                              </p>
                            </div>
                            {cat.groups.map((group) => (
                              <GroupEditor
                                key={group.id}
                                group={group}
                                onUpdate={(patch) => updateGroup(comp.id, cat.id, group.id, patch)}
                                onDelete={() => deleteGroup(comp.id, cat.id, group.id)}
                                onAddDescriptor={() => addDescriptor(comp.id, cat.id, group.id)}
                                onUpdateDescriptor={(descId, patch) => updateDescriptor(comp.id, cat.id, group.id, descId, patch)}
                                onDeleteDescriptor={(descId) => deleteDescriptor(comp.id, cat.id, group.id, descId)}
                              />
                            ))}
                            <button
                              onClick={() => addGroup(comp.id, cat.id)}
                              className="w-full text-xs text-[#1a1d24]/50 hover:text-[#1a1d24] py-2 border border-dashed border-[#1a1d24]/15 rounded-lg flex items-center justify-center gap-1"
                            >
                              <Plus size={12} /> añadir grupo
                            </button>
                          </div>
                        )}
                      </div>
                    );
                  })}
                  <button
                    onClick={() => addCat(comp.id)}
                    className="w-full text-sm text-[#1a1d24]/60 hover:text-[#1a1d24] py-2.5 border border-dashed border-[#1a1d24]/20 rounded-lg flex items-center justify-center gap-1.5"
                  >
                    <Plus size={14} /> añadir categoría
                  </button>
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  );
}

function GroupEditor({ group, onUpdate, onDelete, onAddDescriptor, onUpdateDescriptor, onDeleteDescriptor }) {
  return (
    <div className="border border-[#1a1d24]/10 rounded-lg bg-white">
      <div className="flex items-center gap-2 px-3 py-2 bg-[#faf7f2] border-b border-[#1a1d24]/5">
        <input
          value={group.name}
          onChange={(e) => onUpdate({ name: e.target.value })}
          className="flex-1 text-xs font-semibold uppercase tracking-wider bg-transparent outline-none focus:bg-white px-2 py-1 rounded text-[#1a1d24]/70 placeholder:text-[#1a1d24]/30 placeholder:normal-case placeholder:tracking-normal"
          placeholder="Nombre del grupo (vacío = principal)"
        />
        <select
          value={group.type}
          onChange={(e) => onUpdate({ type: e.target.value })}
          className="text-[10px] uppercase tracking-wider px-2 py-1 rounded border border-[#1a1d24]/10 bg-white"
        >
          <option value="single">Selección única</option>
          <option value="multi">Selección múltiple</option>
        </select>
        <button onClick={onDelete} className="p-1.5 text-[#7c2d12] hover:bg-[#7c2d12]/10 rounded">
          <X size={12} />
        </button>
      </div>
      <div className="p-2 space-y-2">
        {group.descriptors.map((d) => (
          <div key={d.id} className="border border-[#1a1d24]/10 rounded p-2 group bg-[#faf7f2]/50">
            <div className="flex items-center gap-2 mb-1.5">
              <input
                value={d.label || ''}
                onChange={(e) => onUpdateDescriptor(d.id, { label: e.target.value })}
                placeholder="Etiqueta corta (opcional, no aparece en el boletín)"
                className="flex-1 text-[11px] uppercase tracking-wider font-semibold bg-white border border-[#1a1d24]/10 rounded px-2 py-1 outline-none focus:border-[#c2410c]/40 text-[#c2410c] placeholder:text-[#1a1d24]/30 placeholder:normal-case placeholder:tracking-normal placeholder:text-[10px] placeholder:font-normal"
              />
              <button
                onClick={() => onDeleteDescriptor(d.id)}
                className="p-1 text-[#7c2d12]/60 hover:text-[#7c2d12] hover:bg-[#7c2d12]/10 rounded opacity-0 group-hover:opacity-100 transition"
              >
                <X size={12} />
              </button>
            </div>
            <textarea
              value={d.text}
              onChange={(e) => onUpdateDescriptor(d.id, { text: e.target.value })}
              className="w-full text-sm bg-white border border-[#1a1d24]/10 rounded px-2 py-1.5 outline-none focus:border-[#1a1d24]/30 resize-none"
              rows={2}
              placeholder="Frase del descriptor (tal cual aparecerá en el boletín)"
            />
          </div>
        ))}
        <button
          onClick={onAddDescriptor}
          className="w-full text-xs text-[#1a1d24]/40 hover:text-[#1a1d24] py-1.5 flex items-center justify-center gap-1"
        >
          <Plus size={11} /> descriptor
        </button>
      </div>
    </div>
  );
}
