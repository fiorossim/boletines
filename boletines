function GroupBlock({ group, selections, onSetSingle, onToggleMulti }) {
  const sel = selections?.[group.id];
  const isMulti = group.type === 'multi';

  if (group.descriptors.length === 0) {
    return (
      <div className="text-xs text-[#1a1d24]/30 italic py-2 px-3 border border-dashed border-[#1a1d24]/15 rounded-lg">
        {group.name ? `${group.name}: ` : ''}sin descriptores cargados.
      </div>
