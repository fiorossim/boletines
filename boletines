export default function App() {
  const [structure, setStructure] = useState(() => makeDefaultStructure());
  const [periods, setPeriods] = useState(() => makeDefaultPeriods());
  const [students, setStudents] = useState([]);
  const [selectedStudentId, setSelectedStudentId] = useState(null);
  const [activePeriodId, setActivePeriodId] = useState(null);
  const [view, setView] = useState('students');
  const [loaded, setLoaded] = useState(false);
  const [copied, setCopied] = useState(false);

  // load
  useEffect(() => {
    (async () => {
      try {
        const r = await window.storage.get(STORAGE_KEY);
        if (r?.value) {
          const data = JSON.parse(r.value);
          const m = migrate(data);
          if (m.structure) setStructure(m.structure);
          if (m.periods) setPeriods(m.periods);
          if (m.students) setStudents(m.students);
          if (m.selectedStudentId) setSelectedStudentId(m.selectedStudentId);
          if (m.activePeriodId) setActivePeriodId(m.activePeriodId);
        }
      } catch {}
      setLoaded(true);
    })();
  }, []);

  // make sure activePeriodId is set once periods are ready
  useEffect(() => {
    if (loaded && !activePeriodId && periods.length > 0) {
      setActivePeriodId(periods[0].id);
    }
  }, [loaded, activePeriodId, periods]);

  // save
  useEffect(() => {
    if (!loaded) return;
    (async () => {
      try {
        await window.storage.set(STORAGE_KEY, JSON.stringify({
          structure, periods, students, selectedStudentId, activePeriodId
        }));
      } catch {}
    })();
  }, [structure, periods, students, selectedStudentId, activePeriodId, loaded]);

  const selectedStudent = useMemo(
    () => students.find((s) => s.id === selectedStudentId) || null,
    [students, selectedStudentId]
  );

  const boletin = useMemo(
    () => generateBoletin(selectedStudent, structure, activePeriodId),
    [selectedStudent, structure, activePeriodId]
  );

  const activePeriod = periods.find(p => p.id === activePeriodId);

  // students
  const addStudent = () => {
    const name = prompt('Nombre del niño/a:');
    if (!name?.trim()) return;
    const newS = { id: uid(), name: name.trim(), periodSelections: {} };
    setStudents([...students, newS]);
    setSelectedStudentId(newS.id);
  };

  const renameStudent = (id) => {
    const s = students.find((x) => x.id === id);
    const name = prompt('Nuevo nombre:', s?.name);
    if (!name?.trim()) return;
    setStudents(students.map((x) => (x.id === id ? { ...x, name: name.trim() } : x)));
  };

  const removeStudent = (id) => {
    if (!confirm('¿Eliminar este estudiante? Se borrarán sus marcas en todos los períodos.')) return;
    setStudents(students.filter((x) => x.id !== id));
    if (selectedStudentId === id) setSelectedStudentId(null);
  };

  const duplicateStudent = (id) => {
    const s = students.find((x) => x.id === id);
    if (!s) return;
    const name = prompt('Nombre del duplicado:', `${s.name} (copia)`);
    if (!name?.trim()) return;
    const dup = {
      id: uid(),
      name: name.trim(),
      periodSelections: JSON.parse(JSON.stringify(s.periodSelections || {}))
    };
    setStudents([...students, dup]);
    setSelectedStudentId(dup.id);
  };

  const updateStudentSelections = (newSelections) => {
    setStudents(students.map((s) => {
      if (s.id !== selectedStudentId) return s;
      return {
        ...s,
        periodSelections: { ...s.periodSelections, [activePeriodId]: newSelections }
      };
    }));
  };

  const currentSelections = selectedStudent?.periodSelections?.[activePeriodId] || {};

  const setSingleSelection = (groupId, descriptorId) => {
    if (!selectedStudent) return;
    const newSel = { ...currentSelections };
    if (newSel[groupId] === descriptorId) delete newSel[groupId];
    else newSel[groupId] = descriptorId;
    updateStudentSelections(newSel);
  };

  const toggleMultiSelection = (groupId, descriptorId) => {
    if (!selectedStudent) return;
    const newSel = { ...currentSelections };
    const current = Array.isArray(newSel[groupId]) ? newSel[groupId] : [];
    if (current.includes(descriptorId)) {
      const next = current.filter(x => x !== descriptorId);
      if (next.length === 0) delete newSel[groupId];
      else newSel[groupId] = next;
    } else {
      newSel[groupId] = [...current, descriptorId];
    }
    updateStudentSelections(newSel);
  };

  const clearStudentSelections = () => {
    if (!selectedStudent) return;
    if (!confirm(`¿Borrar las marcas de este estudiante en ${activePeriod?.name}?`)) return;
    updateStudentSelections({});
  };

  const copyFromPeriod = () => {
    if (!selectedStudent) return;
    const otherPeriods = periods.filter(p => p.id !== activePeriodId);
    if (otherPeriods.length === 0) return;
    const names = otherPeriods.map((p, i) => `${i + 1}. ${p.name}`).join('\n');
    const choice = prompt(`¿Desde qué período copiar las marcas a ${activePeriod?.name}?\n\n${names}\n\nEscribí el número:`);
    const idx = parseInt(choice, 10) - 1;
    if (isNaN(idx) || idx < 0 || idx >= otherPeriods.length) return;
    const sourcePeriod = otherPeriods[idx];
    const sourceSel = selectedStudent.periodSelections?.[sourcePeriod.id] || {};
    if (Object.keys(sourceSel).length === 0) {
      alert(`${sourcePeriod.name} no tiene marcas para copiar.`);
      return;
    }
    if (!confirm(`Esto reemplaza las marcas actuales de ${activePeriod?.name} con las de ${sourcePeriod.name}. ¿Continuar?`)) return;
    updateStudentSelections(JSON.parse(JSON.stringify(sourceSel)));
  };

  const copyBoletin = async () => {
    try {
      await navigator.clipboard.writeText(`Boletín — ${selectedStudent?.name || ''} — ${activePeriod?.name || ''}\n\n${boletin.plain}`);
      setCopied(true);
      setTimeout(() => setCopied(false), 1500);
    } catch {}
  };

  const downloadBoletin = () => {
    const text = `Boletín — ${selectedStudent?.name || ''} — ${activePeriod?.name || ''}\n\n${boletin.plain}`;
    const blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    const safeName = selectedStudent?.name?.replace(/\s+/g, '-') || 'estudiante';
    const safePeriod = activePeriod?.name?.replace(/\s+/g, '-') || 'periodo';
    a.download = `boletin-${safeName}-${safePeriod}.txt`;
    a.click();
    URL.revokeObjectURL(url);
  };

  // periods CRUD
  const addPeriod = () => {
    const name = prompt('Nombre del período:', `Período ${periods.length + 1}`);
    if (!name?.trim()) return;
    setPeriods([...periods, { id: uid(), name: name.trim() }]);
  };

  const renamePeriod = (id) => {
    const p = periods.find(x => x.id === id);
    const name = prompt('Nuevo nombre:', p?.name);
    if (!name?.trim()) return;
    setPeriods(periods.map(x => x.id === id ? { ...x, name: name.trim() } : x));
  };

  const removePeriod = (id) => {
    if (periods.length <= 1) {
      alert('No se puede eliminar el último período.');
      return;
    }
    if (!confirm('¿Eliminar este período? Se perderán las marcas de todos los estudiantes en este período.')) return;
    setPeriods(periods.filter(x => x.id !== id));
    setStudents(students.map(s => {
      const ps = { ...(s.periodSelections || {}) };
      delete ps[id];
      return { ...s, periodSelections: ps };
    }));
    if (activePeriodId === id) {
      const remaining = periods.filter(x => x.id !== id);
      setActivePeriodId(remaining[0]?.id || null);
    }
  };

  return (
    <div className="min-h-screen bg-[#faf7f2] text-[#1a1d24]" style={{ fontFamily: 'Manrope, ui-sans-serif, system-ui' }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Manrope:wght@400;500;600;700&display=swap');
        .font-display { font-family: 'Fraunces', ui-serif, Georgia; font-optical-sizing: auto; }
        .paper-bg { background-image: radial-gradient(circle at 1px 1px, rgba(26, 29, 36, 0.05) 1px, transparent 0); background-size: 24px 24px; }
        .ink-shadow { box-shadow: 0 1px 0 rgba(26, 29, 36, 0.08), 0 8px 24px -12px rgba(26, 29, 36, 0.12); }
      `}</style>

      <header className="border-b border-[#1a1d24]/10 bg-[#faf7f2]/90 backdrop-blur sticky top-0 z-20">
        <div className="max-w-7xl mx-auto px-6 py-3 flex flex-wrap items-center justify-between gap-3">
          <div className="flex items-baseline gap-3">
            <h1 className="font-display text-2xl font-semibold tracking-tight">Boletines</h1>
            <span className="text-xs text-[#1a1d24]/50 hidden sm:inline">elegí, marcá, redactado.</span>
          </div>

          <div className="flex flex-wrap items-center gap-2">
            <PeriodSelector periods={periods} activeId={activePeriodId} onChange={setActivePeriodId} />
            <nav className="flex items-center gap-1 bg-[#1a1d24]/5 rounded-full p-1">
              <button
                onClick={() => setView('students')}
                className={`flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium transition ${view === 'students' ? 'bg-[#1a1d24] text-[#faf7f2]' : 'text-[#1a1d24]/70 hover:text-[#1a1d24]'}`}
              >
                <Users size={13} /> Estudiantes
              </button>
              <button
                onClick={() => setView('structure')}
                className={`flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium transition ${view === 'structure' ? 'bg-[#1a1d24] text-[#faf7f2]' : 'text-[#1a1d24]/70 hover:text-[#1a1d24]'}`}
              >
                <Settings size={13} /> Estructura
              </button>
            </nav>
          </div>
        </div>
      </header>

      {view === 'students' && (
        <div className="max-w-7xl mx-auto px-6 py-6 grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-6">
          <aside className="lg:sticky lg:top-24 lg:self-start">
            <button
              onClick={addStudent}
              className="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-[#1a1d24] text-[#faf7f2] rounded-lg text-sm font-medium hover:bg-[#1a1d24]/90 transition"
            >
              <UserPlus size={16} /> Añadir estudiante
            </button>
            <ul className="mt-3 space-y-1">
              {students.length === 0 && (
                <li className="text-sm text-[#1a1d24]/50 italic px-3 py-2">Sin estudiantes aún.</li>
              )}
              {students.map((s) => {
                const count = Object.keys(s.periodSelections?.[activePeriodId] || {}).length;
                const active = s.id === selectedStudentId;
                return (
                  <li key={s.id}>
                    <button
                      onClick={() => setSelectedStudentId(s.id)}
                      className={`w-full text-left px-3 py-2.5 rounded-lg transition flex items-center justify-between ${active ? 'bg-[#1a1d24] text-[#faf7f2]' : 'hover:bg-[#1a1d24]/5'}`}
                    >
                      <span className="font-medium text-sm truncate">{s.name}</span>
                      <span className={`text-xs tabular-nums ${active ? 'text-[#faf7f2]/60' : 'text-[#1a1d24]/40'}`}>{count}</span>
                    </button>
                  </li>
                );
              })}
            </ul>
            <p className="text-[10px] text-[#1a1d24]/40 italic mt-3 px-2 leading-snug">
              El número junto a cada nombre cuenta los grupos marcados en {activePeriod?.name?.toLowerCase() || 'el período activo'}.
            </p>
          </aside>

          <main>
            {!selectedStudent ? (
              <EmptyState onAdd={addStudent} hasStudents={students.length > 0} />
            ) : (
              <StudentView
                student={selectedStudent}
                structure={structure}
                activePeriod={activePeriod}
                onSetSingle={setSingleSelection}
                onToggleMulti={toggleMultiSelection}
                onRename={() => renameStudent(selectedStudent.id)}
                onDelete={() => removeStudent(selectedStudent.id)}
                onDuplicate={() => duplicateStudent(selectedStudent.id)}
                onClear={clearStudentSelections}
                onCopyFromPeriod={copyFromPeriod}
                hasOtherPeriods={periods.length > 1}
                boletin={boletin}
                onCopy={copyBoletin}
                onDownload={downloadBoletin}
                copied={copied}
              />
            )}
          </main>
        </div>
      )}

      {view === 'structure' && (
        <StructureEditor
          structure={structure}
          setStructure={setStructure}
          periods={periods}
          onAddPeriod={addPeriod}
          onRenamePeriod={renamePeriod}
          onRemovePeriod={removePeriod}
          onResetDefault={() => {
            if (confirm('Volver a la estructura de ejemplo. Reemplaza competencias, categorías, grupos y descriptores. Estudiantes y períodos se mantienen pero las marcas referirán a IDs viejos y aparecerán como vacías.')) {
              setStructure(makeDefaultStructure());
            }
          }}
        />
      )}
    </div>
  );
}

